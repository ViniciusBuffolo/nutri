{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"],
      "@data/*": ["../../packages/data/*"],
      "@theme/*": ["../../packages/theme/*"],
      "@core/*": ["../../packages/core/*"],
      "@ui/*": ["../../packages/ui/*"],
      "@utils/*": ["../../packages/utils/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts", 
    "**/*.d.ts"
  ]
}